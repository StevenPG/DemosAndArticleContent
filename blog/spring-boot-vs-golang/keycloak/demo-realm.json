{
  "realm": "demo",
  "enabled": true,
  "accessTokenLifespan": 300,
  "sslRequired": "none",
  "comment": "Imported at startup via --import-realm. Defines four OAuth2 client scopes and three confidential clients with service accounts. Because each custom scope is a DEFAULT client scope on its client, Keycloak lists it in the access token's 'scope' claim automatically - no protocol mapper needed. That claim is what both order services and the downstream stub check.",
  "clientScopes": [
    {
      "name": "orders:read",
      "description": "Read orders",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" }
    },
    {
      "name": "orders:write",
      "description": "Create orders",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" }
    },
    {
      "name": "payments:charge",
      "description": "Charge payments",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" }
    },
    {
      "name": "inventory:reserve",
      "description": "Reserve inventory",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" }
    }
  ],
  "clients": [
    {
      "clientId": "orders-api-client",
      "description": "Test client. Use its client-credentials token to call the order services' REST API (scopes orders:read + orders:write).",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "orders-api-client-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "defaultClientScopes": ["orders:read", "orders:write"],
      "optionalClientScopes": []
    },
    {
      "clientId": "payment-client",
      "description": "Used by both order services to call the payment stub.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "payment-client-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "defaultClientScopes": ["payments:charge"],
      "optionalClientScopes": []
    },
    {
      "clientId": "inventory-client",
      "description": "Used by both order services to call the inventory stub.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "inventory-client-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "defaultClientScopes": ["inventory:reserve"],
      "optionalClientScopes": []
    }
  ]
}
